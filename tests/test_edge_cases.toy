// TEST 4: Edge Cases
// Tricky inputs that test rule priority

// 1. Keyword vs Identifier — "iffy" should be IDENT, not IF + IDENT
int iffy = 1;
int whileLoop = 2;
int integer = 3;
int floating = 4;
int returnValue = 5;
int trueFlag = 6;
int falseAlarm = 7;

// 2. Float vs Integer — 3.14 should be FLOAT_LIT, not INT + DOT + INT
float pi = 3.14;
int whole = 42;

// 3. Two-char vs single-char ops
bool eq  = (1 == 1);
bool neq = (1 != 2);
bool leq = (1 <= 2);
bool geq = (2 >= 1);
int assign = 5;

// 4. Adjacent operators without spaces
int x = 1+2-3*4/5%6;
bool y = (1<=2)&&(3>=4)||(5!=6);

// 5. Comments should be completely invisible
/* this is a multi-line
   comment that spans
   three lines */
int afterComment = 100;  // this comment is also ignored
